# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-in-production

# Database Configuration (for production)
# For PlanetScale
DATABASE_URL=mysql://username:password@hostname/database?ssl=true

# For ClearDB (Heroku)
# CLEARDB_DATABASE_URL=mysql://username:password@hostname/database

# For local development
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=iclinic_db

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_USE_TLS=true

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=your-twilio-number

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# Google AI Configuration
GOOGLE_AI_API_KEY=your-google-ai-api-key
  
# Application Settings
APP_NAME=iClinic
APP_VERSION=2.0
ICLINIC_PUBLIC_BASE_URL=https://iclinic-v-2-1.onrender.com
DEBUG=false
PORT=5000
